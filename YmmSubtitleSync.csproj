<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>YmmSubtitleSync</AssemblyName>
    <RootNamespace>YmmSubtitleSync</RootNamespace>
    <Nullable>enable</Nullable>
    <Platforms>x64</Platforms>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <DefineConstants Condition="Exists('Libs/YukkuriMovieMaker.Plugin.dll')">$(DefineConstants);YMM4_SDK</DefineConstants>
  </PropertyGroup>

  <!--
    YMM4のDLLを Libs/ フォルダにコピーしてください。
    YMM4インストール先 (例: C:\ゆっくりMovieMaker4) から:
      YukkuriMovieMaker.Plugin.dll
    DLLがない場合は Stubs/YmmApiStubs.cs のスタブでコンパイルされます。
  -->
  <ItemGroup Condition="Exists('Libs/YukkuriMovieMaker.Plugin.dll')">
    <Reference Include="YukkuriMovieMaker.Plugin">
      <HintPath>Libs/YukkuriMovieMaker.Plugin.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
